# Löneportalen - Environment Variables
# Kopiera denna fil till .env.local och fyll i värden

# API URL (backend)
VITE_API_URL=https://loneprocess-api-922770673146.us-central1.run.app/api/v1

# API-nyckel för autentisering (X-API-Key header)
# Kontakta API-teamet för en giltig nyckel
VITE_LONEPROCESS_API_KEY=din-api-nyckel-här
